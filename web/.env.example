# =============================================================================
# Fluxpage production (Vercel) — copy to .env.local for local dev
# =============================================================================

# Convex deployment URL (HTTP Actions URL from Convex dashboard)
NEXT_PUBLIC_API_URL=https://stoic-caiman-320.convex.site

# Public web app origin (extension login redirect, editor links)
NEXT_PUBLIC_WEB_URL=https://www.fluxpage.com

# -----------------------------------------------------------------------------
# Clerk authentication (required for sign-in on fluxpage.com)
# Get keys: https://dashboard.clerk.com → your app → API Keys
# Also add https://www.fluxpage.com in Clerk → Domains / Redirect URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/sync
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/sync

# Shared secret for Clerk → Convex user sync (same value in Convex dashboard)
CLERK_SYNC_SECRET=

# -----------------------------------------------------------------------------
# Razorpay live billing (amounts in paise: 99900 = ₹999)
# Webhook URL: https://www.fluxpage.com/api/razorpay/webhook
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Same string you enter in Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_WEBHOOK_INTERNAL_SECRET=
RAZORPAY_PLAN_PRO_AMOUNT=19900
RAZORPAY_PLAN_PREMIUM_AMOUNT=39900
NEXT_PUBLIC_RAZORPAY_PRO_DISPLAY=₹199
NEXT_PUBLIC_RAZORPAY_PRO_ORIGINAL_DISPLAY=₹999
NEXT_PUBLIC_RAZORPAY_PREMIUM_DISPLAY=₹399
NEXT_PUBLIC_RAZORPAY_PREMIUM_ORIGINAL_DISPLAY=₹2,499

# AI Provider Keys (at least one required)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# LLM config (optional overrides)
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=minimax/minimax-m2.5:free

# Allowed CORS origins for Convex HTTP (comma-separated, optional extra domains)
ALLOWED_ORIGINS=https://www.fluxpage.com,https://fluxpage.com

# Convex dashboard only (not Vercel): WEB_BASE=https://www.fluxpage.com
